---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { useTranslations } from "../../i18n/utils";

export function getStaticPaths() {
  return [
    { params: { lang: "es" } },
    { params: { lang: "en" } },
  ];
}

const lang = Astro.params.lang as "es" | "en";
const t = useTranslations(lang);

const localizedRoutes = {
  es: {
    blog: "/es/blog",
    langSwitch: "/en",
  },
  en: {
    blog: "/en/blog",
    langSwitch: "/es",
  },
};

const routes = localizedRoutes[lang];
---

<BaseLayout title={lang === "es" ? "Inicio | ZOOBLOG" : "Home | ZOOBLOG"} switchUrl={routes.langSwitch}>

  <section class="relative overflow-hidden bg-gradient-to-br from-emerald-50 via-white to-sky-50">
    <div class="mx-auto grid min-h-[85vh] max-w-6xl items-center gap-16 px-6 py-24 lg:grid-cols-2">

      <!-- TEXTO -->
      <div data-scroll-reveal class="relative z-10">
        <span class="inline-flex rounded-full bg-emerald-100 px-4 py-2 text-sm font-bold text-emerald-700">
          {lang === "es" ? "Todo sobre el reino animal" : "All about the animal kingdom"}
        </span>

        <h1
          data-hero-title
          class="mt-6 text-5xl font-black leading-tight tracking-tight text-slate-950 md:text-6xl"
        >
          {lang === "es" ? "ZOOBLOGÍA DE LOS ANIMALES" : "ANIMAL ZOOLOGY"}
        </h1>

        <p data-scroll-reveal class="mt-6 max-w-xl text-lg leading-8 text-slate-600">
          {lang === "es"
            ? "Explora datos, especies, hábitats y curiosidades sobre los animales que habitan nuestro planeta."
            : "Explore facts, species, habitats and curiosities about the animals that inhabit our planet."}
        </p>

        <div data-scroll-reveal class="mt-8 flex flex-wrap gap-4">
          <a
            href={routes.blog}
            class="inline-flex rounded-2xl bg-emerald-600 px-6 py-3 font-bold text-white shadow-lg shadow-emerald-200 transition hover:-translate-y-1 hover:bg-emerald-700"
          >
            {t("viewBlog")}
          </a>
          <a
            href={routes.blog}
            class="inline-flex rounded-2xl border border-slate-300 bg-white px-6 py-3 font-bold text-slate-700 transition hover:-translate-y-1 hover:border-emerald-400 hover:text-emerald-700"
          >
            {t("exploreSpecies")}
          </a>
        </div>
      </div>

      <!-- IMÁGENES -->
      <div data-scroll-reveal class="relative">
        <div class="absolute -right-8 -top-8 h-48 w-48 rounded-full bg-sky-200/60 blur-3xl"></div>
        <div class="absolute -bottom-8 -left-8 h-48 w-48 rounded-full bg-emerald-200/60 blur-3xl"></div>

        <div class="relative grid grid-cols-12 gap-3">
          <div class="group relative col-span-7 row-span-2 overflow-hidden rounded-3xl">
            <img
              data-scroll-image
              src="/images/guacamaya.jpg"
              alt={lang === "es" ? "Guacamaya en su hábitat natural" : "Macaw in its natural habitat"}
              class="aspect-[3/4] h-full w-full rounded-3xl object-cover"
            />
          </div>

          <div class="group relative col-span-5 overflow-hidden rounded-3xl">
            <img
              data-scroll-image
              src="/images/jaguar.jpg"
              alt={lang === "es" ? "Jaguar en la selva" : "Jaguar in the jungle"}
              class="aspect-[4/3] h-full w-full rounded-3xl object-cover"
            />
          </div>

          <div class="group relative col-span-5 overflow-hidden rounded-3xl">
            <img
              data-scroll-image
              src="/images/tlacuache.jpg"
              alt={lang === "es" ? "Tlacuache en su hábitat" : "Opossum in its habitat"}
              class="aspect-[4/3] h-full w-full rounded-3xl object-cover"
            />
          </div>

          <div class="group relative col-span-12 overflow-hidden rounded-3xl">
            <img
              data-scroll-image
              src="/images/leopardo_nieve.jpg"
              alt={lang === "es" ? "Leopardo de las nieves" : "Snow leopard"}
              class="aspect-[21/9] h-full w-full rounded-3xl object-cover"
            />
          </div>
        </div>
      </div>

    </div>
  </section>

</BaseLayout>
