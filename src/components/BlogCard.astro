---
import type { NormalizedPost } from "../prismicio";

const { post, lang } = Astro.props as { post: NormalizedPost; lang: string };

const date = post.publishedAt
  ? new Date(post.publishedAt).toLocaleDateString(lang === "es" ? "es-MX" : "en-US")
  : "";
---

<a
  href={`/${lang}/blog/${post.uid}`}
  class="group block overflow-hidden rounded-[2rem] bg-white shadow-xl shadow-emerald-100 transition duration-300 hover:-translate-y-2"
>
  {post.image && (
    <img
      src={post.image}
      alt={post.imageAlt}
      class="h-56 w-full object-cover transition duration-500 group-hover:scale-105"
    />
  )}

  <div class="p-7">
    {date && (
      <p class="text-sm font-bold text-emerald-700">{date}</p>
    )}

    <h2 class="mt-3 text-2xl font-black text-slate-950">
      {post.title}
    </h2>

    <p class="mt-3 leading-7 text-slate-600">
      {post.description}
    </p>

    <div class="mt-5 flex flex-wrap gap-2">
      {post.tags.map((tag) => (
        <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-bold text-emerald-700">
          #{tag}
        </span>
      ))}
    </div>
  </div>
</a>
