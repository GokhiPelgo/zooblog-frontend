---
import BaseLayout from "../../../layouts/BaseLayout.astro";

export function getStaticPaths() {
  return [{ params: { lang: "es" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as "es" | "en";

const copy = {
  es: {
    eyebrow: "Tutoriales",
    title: "Tutoriales",
    subtitle: "Guías paso a paso del mundo animal.",
    empty: "Aún no hay tutoriales publicados.",
    loading: "Cargando tutoriales…",
    read: "Leer tutorial",
  },
  en: {
    eyebrow: "Tutorials",
    title: "Tutorials",
    subtitle: "Step-by-step guides from the animal world.",
    empty: "No tutorials published yet.",
    loading: "Loading tutorials…",
    read: "Read tutorial",
  },
}[lang];

const switchUrl = lang === "es" ? "/en/tutoriales" : "/es/tutoriales";
const API = import.meta.env.PUBLIC_API_URL ?? "http://localhost:8000";
---

<BaseLayout title={`${copy.title} | ZOOBLOG`} description={copy.subtitle} switchUrl={switchUrl}>
  <section class="min-h-screen bg-gradient-to-br from-emerald-50 via-white to-sky-50 px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-14 max-w-3xl">
        <span class="inline-flex rounded-full bg-emerald-100 px-4 py-2 text-sm font-bold text-emerald-700">
          {copy.eyebrow}
        </span>
        <h1 class="mt-6 text-5xl font-black tracking-tight text-slate-950 md:text-6xl">{copy.title}</h1>
        <p class="mt-6 text-lg leading-8 text-slate-600">{copy.subtitle}</p>
      </div>

      <div id="tut-grid" class="grid gap-8 md:grid-cols-2 lg:grid-cols-3"></div>
      <p id="tut-status" class="text-slate-500">{copy.loading}</p>
    </div>
  </section>

  <script define:vars={{ API, lang, copy }}>
    const grid = document.getElementById("tut-grid");
    const status = document.getElementById("tut-status");

    function resolveImg(img) {
      if (!img) return null;
      if (img.startsWith("http")) return img;
      const clean = img.replace(/^\/+/, "").replace(/^storage\//, "");
      return `${API}/storage/${clean}`;
    }

    (async () => {
      try {
        const res = await fetch(`${API}/api/tutorials?lang=${lang}`, {
          headers: { Accept: "application/json" },
        });
        const tutorials = res.ok ? await res.json() : [];

        if (!tutorials.length) {
          status.textContent = copy.empty;
          return;
        }

        status.style.display = "none";
        grid.innerHTML = tutorials
          .map((t) => {
            const img = resolveImg(t.cover_image);
            return `<a href="/${lang}/tutoriales/ver?slug=${encodeURIComponent(t.slug)}"
              class="group block overflow-hidden rounded-3xl border border-emerald-100 bg-white shadow-lg shadow-emerald-900/5 transition hover:-translate-y-1">
              ${img ? `<img src="${img}" alt="${t.title}" class="aspect-[16/9] w-full object-cover" />` : ""}
              <div class="p-6">
                ${t.level ? `<span class="text-xs font-black uppercase tracking-wider text-emerald-600">${t.level}</span>` : ""}
                <h2 class="mt-2 text-xl font-black text-slate-950 group-hover:text-emerald-700">${t.title}</h2>
                ${t.excerpt ? `<p class="mt-3 text-sm leading-6 text-slate-600">${t.excerpt}</p>` : ""}
                <span class="mt-4 inline-flex text-sm font-bold text-emerald-700">${copy.read} &rarr;</span>
              </div>
            </a>`;
          })
          .join("");
      } catch {
        status.textContent = copy.empty;
      }
    })();
  </script>
</BaseLayout>
